# Скопируйте в .env: cp .env.example .env

# Модели (дефолты совпадают с docker-compose)
LLM_MODEL=qwen3:14b
EMBED_MODEL=bge-m3

# Qdrant (для локального запуска вне docker оставьте localhost)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Каталоги
DOCS_DIR=./data/docs
STORAGE_DIR=./storage
